{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "framework": "nextjs",
  "installCommand": "npm install --no-audit --no-fund",
  "buildCommand": "npm run build",
  "headers": [
    {
      "source": "/demo/(.*)\\.pdf",
      "headers": [
        { "key": "Content-Disposition", "value": "inline" },
        { "key": "Content-Type", "value": "application/pdf" }
      ]
    },
    {
      "source": "/records/(.*)\\.pdf",
      "headers": [
        { "key": "Content-Disposition", "value": "inline" },
        { "key": "Content-Type", "value": "application/pdf" }
      ]
    }
  ]
}
